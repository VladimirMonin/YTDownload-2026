@echo off
title YT Downloader — DEBUG
chcp 65001 >nul

:: Установить уровень логирования DEBUG — все логи vidны в терминале
set YTDL_LOG_LEVEL=DEBUG

:: Показать что запускаем
echo ============================================================
echo  YT Downloader  [DEBUG MODE]
echo  Все логи уровня DEBUG и выше выводятся в консоль
echo  Закройте это окно чтобы завершить приложение
echo ============================================================
echo.

:: Запускаем через UV (управляет venv автоматически)
uv run python app.py

:: Если приложение упало или закрылось — держим окно открытым
echo.
echo ============================================================
echo  Приложение завершилось (код выхода: %ERRORLEVEL%)
echo  Нажмите любую клавишу для закрытия окна...
echo ============================================================
pause >nul
